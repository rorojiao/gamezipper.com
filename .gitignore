node_modules/
package-lock.json
*.spec.js
register*.js
regression-test.js
test-all-games.js
gm-upload.js
gm-retry.js
test-results/
dist/

# Claude Code worktrees
.claude/worktrees/
tests/__pycache__/
**/__pycache__/
*.pyc
*.py
# Exception: keep game Python sources if explicitly tracked
!magic-sort/*.py
!scripts/*.py

# Pipeline state file (runtime only, regenerated each cron run)
.game-pipeline-status

# Temporary reencode script (one-off build tool, not part of game runtime)
magic-sort/reencode_and_inject.py
magic-sort/gen_log*.txt

# Don't commit og-images/ (47MB) - used for OpenGraph meta but regenerated

# Don't commit build artifacts
slice-it-all/build.log
slice-it-all/PROMPT.txt
slice-it-all/BENCHMARK.md

# Test evidence (screenshots, results.json) - regenerated each run
qa-round-*/evidence/
qa-round-*/results.json
qa-round-*/playability_results.json
qa-round-*/real-play-results.json

# Empty analytics DB placeholder (runtime artifact)
analytics.db
*.db
