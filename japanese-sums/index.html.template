<script>
// === LEVEL DATA ===
const LEVELS = __LEVELS_DATA__;

// === STATE ===
let currentLevelIdx = 0;
let level = null; // current level object
let grid = []; // player grid: 0=empty, -1=marked empty, 1..N=digit
let selectedCell = null; // {r, c}
let selectedDigit = 0; // 0=no tool selected (click to cycle), 1..N=place digit, -1=erase
let hintsLeft = 3;
let hintsUsed = 0;
let errorCount = 0;
let stars = 0;
let settings = { music: true, sfx: true, autocheck: false };
let audioCtx = null;
let musicGain = null;
let musicInterval = null;
let progress = {}; // levelNum -> {stars, completed}

// Canvas
const canvas = document.getElementById('board');
const ctx = canvas.getContext('2d');
let cellSize = 50;
let cluePad = 40;

// === INIT ===
function init() {
  loadProgress();
  loadSettings();
  renderMenu();
  setupCanvas();
}

function loadProgress() {
  try {
    const saved = localStorage.getItem('js-progress');
    if (saved) progress = JSON.parse(saved);
  } catch(e) { progress = {}; }
}

function saveProgress() {
  try { localStorage.setItem('js-progress', JSON.stringify(progress)); } catch(e) {}
}

function loadSettings() {
  try {
    const saved = localStorage.getItem('js-settings');
    if (saved) {
      settings = {...settings, ...JSON.parse(saved)};
    }
  } catch(e) {}
  updateSettingsUI();
}

function saveSettings() {
  try { localStorage.setItem('js-settings', JSON.stringify(settings)); } catch(e) {}
}

function updateSettingsUI() {
  document.getElementById('set-music').classList.toggle('on', settings.music);
  document.getElementById('set-sfx').classList.toggle('on', settings.sfx);
  document.getElementById('set-autocheck').classList.toggle('on', settings.autocheck);
}

// === MENU ===
function renderMenu() {
  const tierList = document.getElementById('tier-list');
  const tierNames = ['Beginner', 'Easy', 'Medium', 'Hard', 'Expert'];
  const tierColors = ['#4fc3f7', '#66bb6a', '#ffd54f', '#ff7043', '#ab47bc'];
  let html = '';
  for (let t = 0; t < 5; t++) {
    const levels = LEVELS.filter(l => l.t === t);
    html += `<div class="tier-section">`;
    html += `<div class="tier-title" style="color:${tierColors[t]}">${tierNames[t]} (${levels[0].N}×${levels[0].N})</div>`;
    html += `<div class="level-grid">`;
    for (const lv of levels) {
      const p = progress[lv.n];
      const stars = p ? p.stars : 0;
      const starStr = stars > 0 ? '⭐'.repeat(stars) : '';
      html += `<button class="level-btn" onclick="startLevel(${lv.n - 1})">${lv.n}<span class="stars">${starStr}</span></button>`;
    }
    html += `</div></div>`;
  }
  tierList.innerHTML = html;
}

// === GAME ===
function startLevel(idx) {
  currentLevelIdx = idx;
  level = LEVELS[idx];
  hintsLeft = 3;
  hintsUsed = 0;
  errorCount = 0;
  stars = 0;
  selectedCell = null;
  selectedDigit = 0;
  const N = level.N;
  grid = Array.from({length: N}, () => Array(N).fill(0));
  document.getElementById('menu').style.display = 'none';
  document.getElementById('game').style.display = 'flex';
  document.getElementById('lvl-title').textContent = `Level ${level.n}`;
  document.getElementById('info-hints').textContent = `💡 ${hintsLeft}`;
  document.getElementById('info-errors').textContent = `❌ ${errorCount}`;
  document.getElementById('info-stars').textContent = `⭐ 0`;
  setupCanvas();
  renderDigitTools();
  startMusic();
  draw();
}

function goMenu() {
  document.getElementById('game').style.display = 'none';
  document.getElementById('menu').style.display = 'flex';
  document.getElementById('win-overlay').classList.remove('show');
  stopMusic();
  renderMenu();
}

function nextLevel() {
  document.getElementById('win-overlay').classList.remove('show');
  if (currentLevelIdx + 1 < LEVELS.length) {
    startLevel(currentLevelIdx + 1);
  } else {
    goMenu();
  }
}

function restartLevel() {
  startLevel(currentLevelIdx);
}

function renderDigitTools() {
  const N = level.N;
  const tools = document.getElementById('digit-tools');
  let html = '';
  for (let d = 1; d <= N; d++) {
    html += `<button class="tool-btn ${selectedDigit === d ? 'active' : ''}" onclick="selectDigit(${d})">${d}</button>`;
  }
  html += `<button class="tool-btn erase ${selectedDigit === -1 ? 'active' : ''}" onclick="selectDigit(-1)">✕</button>`;
  html += `<button class="tool-btn ${selectedDigit === 0 ? 'active' : ''}" onclick="selectDigit(0)" style="font-size:12px">auto</button>`;
  tools.innerHTML = html;
}

function selectDigit(d) {
  selectedDigit = d;
  renderDigitTools();
}

// === CANVAS ===
function setupCanvas() {
  if (!level) return;
  const N = level.N;
  const maxW = Math.min(window.innerWidth - 36, 520);
  cluePad = N <= 5 ? 36 : (N <= 6 ? 34 : 32);
  const availableForGrid = maxW - cluePad - 10;
  cellSize = Math.floor(availableForGrid / N);
  cellSize = Math.max(32, Math.min(cellSize, 65));
  const totalSize = cellSize * N + cluePad + 10;
  canvas.width = totalSize;
  canvas.height = totalSize;
  canvas.style.width = totalSize + 'px';
  canvas.style.height = totalSize + 'px';
  draw();
}

function draw() {
  if (!level) return;
  const N = level.N;
  const W = canvas.width;
  const H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  // Background
  ctx.fillStyle = '#141b3d';
  ctx.fillRect(0, 0, W, H);

  const gx = cluePad;
  const gy = cluePad;

  // Draw clue areas (lighter background)
  ctx.fillStyle = '#1a2347';
  ctx.fillRect(0, 0, gx, gy + cellSize * N); // left-top corner + left strip
  ctx.fillRect(gx, 0, cellSize * N, gy); // top strip

  // Draw cells
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N; c++) {
      const x = gx + c * cellSize;
      const y = gy + r * cellSize;
      const val = grid[r][c];

      // Cell background
      if (val === -1) {
        // Marked empty (black)
        ctx.fillStyle = '#2a2a3e';
      } else if (val > 0) {
        ctx.fillStyle = '#1e3a5f';
      } else {
        ctx.fillStyle = '#232d5c';
      }
      ctx.fillRect(x + 1, y + 1, cellSize - 2, cellSize - 2);

      // Cell border
      ctx.strokeStyle = '#2d3a6b';
      ctx.lineWidth = 1;
      ctx.strokeRect(x + 0.5, y + 0.5, cellSize - 1, cellSize - 1);

      // Highlight selected cell
      if (selectedCell && selectedCell.r === r && selectedCell.c === c) {
        ctx.strokeStyle = '#4fc3f7';
        ctx.lineWidth = 3;
        ctx.strokeRect(x + 1.5, y + 1.5, cellSize - 3, cellSize - 3);
      }

      // Draw value
      if (val > 0) {
        const sol = level.s[r][c];
        // Check if correct
        const correct = (sol === val);
        ctx.fillStyle = correct ? '#e0e6ff' : '#ef5350';
        ctx.font = `bold ${Math.floor(cellSize * 0.55)}px sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(String(val), x + cellSize / 2, y + cellSize / 2 + 2);
      } else if (val === -1) {
        // Marked empty dot
        ctx.fillStyle = '#555';
        ctx.beginPath();
        ctx.arc(x + cellSize / 2, y + cellSize / 2, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    }
  }

  // Draw row clues (left side)
  ctx.font = `bold ${Math.floor(cluePad * 0.38)}px sans-serif`;
  ctx.textAlign = 'right';
  ctx.textBaseline = 'middle';
  for (let r = 0; r < N; r++) {
    const clues = level.r[r] || [];
    const y = gy + r * cellSize + cellSize / 2;
    // Check if row is satisfied
    const satisfied = isLineSatisfied('row', r);
    ctx.fillStyle = satisfied ? '#66bb6a' : '#ffd54f';
    if (clues.length === 0) {
      ctx.fillText('0', gx - 4, y);
    } else {
      const text = clues.join(' ');
      ctx.fillText(text, gx - 4, y);
    }
  }

  // Draw column clues (top)
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  for (let c = 0; c < N; c++) {
    const clues = level.c[c] || [];
    const x = gx + c * cellSize + cellSize / 2;
    const satisfied = isLineSatisfied('col', c);
    ctx.fillStyle = satisfied ? '#66bb6a' : '#ffd54f';
    if (clues.length === 0) {
      ctx.fillText('0', x, gy - 4);
    } else {
      // Stack multiple clues vertically
      const fontSize = Math.floor(cluePad * 0.38);
      const lineH = fontSize + 2;
      const startY = gy - 4 - (clues.length - 1) * lineH;
      for (let i = 0; i < clues.length; i++) {
        ctx.fillText(String(clues[i]), x, startY + i * lineH);
      }
    }
  }
}

function isLineSatisfied(type, idx) {
  const N = level.N;
  let line;
  let clues;
  if (type === 'row') {
    line = grid[idx];
    clues = level.r[idx] || [];
  } else {
    line = [];
    for (let r = 0; r < N; r++) line.push(grid[r][idx]);
    clues = level.c[idx] || [];
  }
  // Compute current groups
  const groups = [];
  let cur = [];
  for (const v of line) {
    if (v > 0) cur.push(v);
    else { if (cur.length > 0) { groups.push(cur.reduce((a,b)=>a+b,0)); cur = []; } }
  }
  if (cur.length > 0) groups.push(cur.reduce((a,b)=>a+b,0));
  // Compare with clues
  if (groups.length !== clues.length) return false;
  for (let i = 0; i < clues.length; i++) {
    if (groups[i] !== clues[i]) return false;
  }
  // Also check no repeats in the line
  const digits = line.filter(v => v > 0);
  if (new Set(digits).size !== digits.length) return false;
  return true;
}

// === INTERACTION ===
canvas.addEventListener('click', (e) => {
  const pos = getCellFromEvent(e);
  if (!pos) return;
  handleCellClick(pos.r, pos.c);
});

canvas.addEventListener('contextmenu', (e) => {
  e.preventDefault();
  const pos = getCellFromEvent(e);
  if (!pos) return;
  // Right-click toggles marked-empty
  if (grid[pos.r][pos.c] === -1) {
    grid[pos.r][pos.c] = 0;
  } else {
    grid[pos.r][pos.c] = -1;
  }
  playSfx('erase');
  checkAutoWin();
  draw();
});

// Touch support
let touchTimer = null;
let touchPos = null;
canvas.addEventListener('touchstart', (e) => {
  e.preventDefault();
  const pos = getCellFromEvent(e.touches[0]);
  if (!pos) return;
  touchPos = pos;
  touchTimer = setTimeout(() => {
    // Long press = toggle empty
    if (touchPos) {
      if (grid[touchPos.r][touchPos.c] === -1) {
        grid[touchPos.r][touchPos.c] = 0;
      } else {
        grid[touchPos.r][touchPos.c] = -1;
      }
      playSfx('erase');
      checkAutoWin();
      draw();
      touchPos = null;
    }
  }, 500);
}, {passive: false});

canvas.addEventListener('touchend', (e) => {
  e.preventDefault();
  if (touchTimer) { clearTimeout(touchTimer); touchTimer = null; }
  if (touchPos) {
    handleCellClick(touchPos.r, touchPos.c);
    touchPos = null;
  }
}, {passive: false});

function getCellFromEvent(e) {
  if (!level) return null;
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  const x = (e.clientX - rect.left) * scaleX;
  const y = (e.clientY - rect.top) * scaleY;
  const c = Math.floor((x - cluePad) / cellSize);
  const r = Math.floor((y - cluePad) / cellSize);
  if (r < 0 || r >= level.N || c < 0 || c >= level.N) return null;
  return {r, c};
}

function handleCellClick(r, c) {
  selectedCell = {r, c};
  const N = level.N;
  if (selectedDigit > 0) {
    // Place specific digit
    if (grid[r][c] === selectedDigit) {
      grid[r][c] = 0; // toggle off
    } else {
      grid[r][c] = selectedDigit;
    }
    playSfx('place');
  } else if (selectedDigit === -1) {
    // Erase / mark empty
    if (grid[r][c] === -1) grid[r][c] = 0;
    else grid[r][c] = -1;
    playSfx('erase');
  } else {
    // Auto mode: cycle 0 -> 1 -> 2 -> ... -> N -> -1 -> 0
    const cur = grid[r][c];
    if (cur === 0) grid[r][c] = 1;
    else if (cur === N) grid[r][c] = -1;
    else if (cur === -1) grid[r][c] = 0;
    else grid[r][c] = cur + 1;
    playSfx('place');
  }
  checkAutoWin();
  draw();
}

function checkAutoWin() {
  if (settings.autocheck) {
    if (checkWin()) {
      onWin();
    }
  }
}

// === CHECK WIN ===
function checkWin() {
  const N = level.N;
  // Every cell must match solution
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N; c++) {
      const sol = level.s[r][c];
      const ply = grid[r][c];
      if (sol > 0 && ply !== sol) return false;
      if (sol === 0 && ply > 0) return false;
    }
  }
  return true;
}

function checkSolution() {
  if (checkWin()) {
    onWin();
    return;
  }
  // Count errors
  let errs = 0;
  const N = level.N;
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N; c++) {
      const sol = level.s[r][c];
      const ply = grid[r][c];
      if (ply > 0 && sol !== ply) errs++;
      if (ply === 0 && sol > 0) errs++; // missing
    }
  }
  if (errs === 0) {
    showToast('Almost there! Check empty cells.', 'info');
  } else {
    errorCount = errs;
    document.getElementById('info-errors').textContent = `❌ ${errorCount}`;
    showToast(`${errs} error(s) found`, 'error');
  }
  draw();
}

// === HINT ===
function useHint() {
  if (hintsLeft <= 0) {
    showToast('No hints left!', 'error');
    return;
  }
  const N = level.N;
  // Find a wrong/empty cell
  const candidates = [];
  for (let r = 0; r < N; r++) {
    for (let c = 0; c < N; c++) {
      if (grid[r][c] !== level.s[r][c] || (level.s[r][c] > 0 && grid[r][c] !== level.s[r][c])) {
        candidates.push({r, c});
      }
    }
  }
  if (candidates.length === 0) {
    showToast('Already solved!', 'info');
    return;
  }
  const pick = candidates[Math.floor(Math.random() * candidates.length)];
  grid[pick.r][pick.c] = level.s[pick.r][pick.c];
  hintsLeft--;
  hintsUsed++;
  document.getElementById('info-hints').textContent = `💡 ${hintsLeft}`;
  playSfx('hint');
  showToast(`Hint: cell (${pick.r+1},${pick.c+1}) = ${level.s[pick.r][pick.c]}`, 'info');
  checkAutoWin();
  draw();
}

// === WIN ===
function onWin() {
  // Calculate stars
  stars = 3;
  if (hintsUsed > 0) stars = Math.max(1, 3 - hintsUsed);
  // Save progress
  const prev = progress[level.n];
  if (!prev || prev.stars < stars) {
    progress[level.n] = {stars, completed: true};
    saveProgress();
  }
  document.getElementById('win-stars').textContent = '⭐'.repeat(stars) + '☆'.repeat(3 - stars);
  document.getElementById('win-sub').textContent = `${level.tier || ''} · Level ${level.n}`;
  document.getElementById('next-btn').style.display = (currentLevelIdx + 1 < LEVELS.length) ? '' : 'none';
  document.getElementById('win-overlay').classList.add('show');
  playSfx('win');
  spawnConfetti();
  stopMusic();
}

function spawnConfetti() {
  const colors = ['#4fc3f7', '#66bb6a', '#ffd54f', '#ef5350', '#ab47bc'];
  for (let i = 0; i < 50; i++) {
    const el = document.createElement('div');
    el.className = 'confetti';
    el.style.background = colors[Math.floor(Math.random() * colors.length)];
    el.style.left = Math.random() * window.innerWidth + 'px';
    el.style.top = '-10px';
    el.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    document.body.appendChild(el);
    const duration = 2000 + Math.random() * 2000;
    const drift = (Math.random() - 0.5) * 200;
    el.animate([
      {transform: 'translate(0, 0) rotate(0deg)', opacity: 1},
      {transform: `translate(${drift}px, ${window.innerHeight + 20}px) rotate(${Math.random()*720}deg)`, opacity: 0}
    ], {duration, easing: 'cubic-bezier(0.5, 0, 0.5, 1)'});
    setTimeout(() => el.remove(), duration);
  }
}

// === TOAST ===
let toastTimer = null;
function showToast(msg, type = 'info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + (type === 'error' ? 'error' : type === 'win' ? 'win' : '');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2000);
}

// === SETTINGS ===
function toggleSettings() {
  document.getElementById('settings').classList.toggle('show');
}

function toggleSetting(key, el) {
  settings[key] = !settings[key];
  el.classList.toggle('on', settings[key]);
  saveSettings();
  if (key === 'music') {
    if (settings.music) startMusic(); else stopMusic();
  }
}

// === AUDIO ===
function initAudio() {
  if (audioCtx) return;
  try {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    musicGain = audioCtx.createGain();
    musicGain.gain.value = 0.06;
    musicGain.connect(audioCtx.destination);
  } catch(e) {}
}

function startMusic() {
  if (!settings.music) return;
  initAudio();
  if (!audioCtx) return;
  if (audioCtx.state === 'suspended') audioCtx.resume();
  stopMusic();
  const chords = [
    [261.63, 329.63, 392.00, 493.88], // Cmaj7
    [293.66, 349.23, 440.00, 587.33], // Dm7
    [220.00, 261.63, 329.63, 440.00], // Am7
    [196.00, 246.94, 293.66, 392.00], // G
  ];
  let chordIdx = 0;
  function playChord() {
    if (!audioCtx || !settings.music) return;
    const chord = chords[chordIdx];
    const now = audioCtx.currentTime;
    for (const freq of chord) {
      const osc = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      osc.type = 'sine';
      osc.frequency.value = freq;
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.3, now + 0.5);
      g.gain.linearRampToValueAtTime(0, now + 3.5);
      osc.connect(g);
      g.connect(musicGain);
      osc.start(now);
      osc.stop(now + 4);
    }
    chordIdx = (chordIdx + 1) % chords.length;
  }
  playChord();
  musicInterval = setInterval(playChord, 4000);
}

function stopMusic() {
  if (musicInterval) { clearInterval(musicInterval); musicInterval = null; }
}

function playSfx(type) {
  if (!settings.sfx) return;
  initAudio();
  if (!audioCtx) return;
  if (audioCtx.state === 'suspended') audioCtx.resume();
  const now = audioCtx.currentTime;
  const osc = audioCtx.createOscillator();
  const g = audioCtx.createGain();
  osc.connect(g);
  g.connect(audioCtx.destination);
  switch(type) {
    case 'place':
      osc.type = 'sine';
      osc.frequency.setValueAtTime(523.25, now);
      osc.frequency.exponentialRampToValueAtTime(659.25, now + 0.08);
      g.gain.setValueAtTime(0.15, now);
      g.gain.exponentialRampToValueAtTime(0.01, now + 0.15);
      osc.start(now); osc.stop(now + 0.15);
      break;
    case 'erase':
      osc.type = 'sine';
      osc.frequency.setValueAtTime(392, now);
      osc.frequency.exponentialRampToValueAtTime(261.63, now + 0.1);
      g.gain.setValueAtTime(0.12, now);
      g.gain.exponentialRampToValueAtTime(0.01, now + 0.12);
      osc.start(now); osc.stop(now + 0.12);
      break;
    case 'hint':
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(659.25, now);
      osc.frequency.setValueAtTime(783.99, now + 0.1);
      g.gain.setValueAtTime(0.15, now);
      g.gain.exponentialRampToValueAtTime(0.01, now + 0.25);
      osc.start(now); osc.stop(now + 0.25);
      break;
    case 'win':
      [523.25, 659.25, 783.99, 1046.50].forEach((freq, i) => {
        const o = audioCtx.createOscillator();
        const gg = audioCtx.createGain();
        o.type = 'triangle';
        o.frequency.value = freq;
        o.connect(gg);
        gg.connect(audioCtx.destination);
        const t = now + i * 0.12;
        gg.gain.setValueAtTime(0.15, t);
        gg.gain.exponentialRampToValueAtTime(0.01, t + 0.3);
        o.start(t); o.stop(t + 0.3);
      });
      osc.stop(now);
      break;
    case 'error':
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(200, now);
      osc.frequency.exponentialRampToValueAtTime(100, now + 0.2);
      g.gain.setValueAtTime(0.1, now);
      g.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
      osc.start(now); osc.stop(now + 0.2);
      break;
  }
}

// === KEYBOARD ===
document.addEventListener('keydown', (e) => {
  if (!level || document.getElementById('game').style.display === 'none') return;
  if (!selectedCell) return;
  const {r, c} = selectedCell;
  const N = level.N;
  if (e.key >= '1' && e.key <= '9') {
    const d = parseInt(e.key);
    if (d >= 1 && d <= N) {
      grid[r][c] = (grid[r][c] === d) ? 0 : d;
      playSfx('place');
      checkAutoWin();
      draw();
    }
  } else if (e.key === '0' || e.key === 'Delete' || e.key === 'Backspace') {
    grid[r][c] = 0;
    playSfx('erase');
    draw();
  } else if (e.key === ' ') {
    e.preventDefault();
    grid[r][c] = grid[r][c] === -1 ? 0 : -1;
    playSfx('erase');
    draw();
  } else if (e.key === 'h' || e.key === 'H') {
    useHint();
  } else if (e.key === 'r' || e.key === 'R') {
    restartLevel();
  } else if (e.key === 'Escape') {
    goMenu();
  } else if (e.key === 'ArrowUp') { e.preventDefault(); if (r > 0) { selectedCell = {r: r-1, c}; draw(); } }
  else if (e.key === 'ArrowDown') { e.preventDefault(); if (r < N-1) { selectedCell = {r: r+1, c}; draw(); } }
  else if (e.key === 'ArrowLeft') { e.preventDefault(); if (c > 0) { selectedCell = {r, c: c-1}; draw(); } }
  else if (e.key === 'ArrowRight') { e.preventDefault(); if (c < N-1) { selectedCell = {r, c: c+1}; draw(); } }
});

// === RESIZE ===
window.addEventListener('resize', () => { setupCanvas(); });

// === START ===
init();
</script>

