<style>
:root {
  --bg: #0a0e27;
  --bg2: #141b3d;
  --panel: #1a2347;
  --panel2: #232d5c;
  --accent: #4fc3f7;
  --accent2: #66bb6a;
  --gold: #ffd54f;
  --red: #ef5350;
  --text: #e0e6ff;
  --text2: #8a9ac0;
  --border: #2d3a6b;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}
.gz-sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); border: 0;
}
#app {
  max-width: 600px;
  margin: 0 auto;
  padding: 10px;
}
/* Menu */
#menu {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 20px 0;
}
.menu-title {
  text-align: center;
  font-size: 28px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.menu-desc {
  text-align: center;
  color: var(--text2);
  font-size: 14px;
  line-height: 1.5;
}
.tier-section {
  background: var(--panel);
  border-radius: 12px;
  padding: 12px;
}
.tier-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 8px;
}
.level-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 6px;
}
.level-btn {
  aspect-ratio: 1;
  border: none;
  border-radius: 8px;
  background: var(--panel2);
  color: var(--text);
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  transition: transform 0.15s, background 0.15s;
  position: relative;
}
.level-btn:hover { background: var(--accent); color: var(--bg); transform: scale(1.05); }
.level-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.level-btn .stars {
  font-size: 8px;
  color: var(--gold);
  position: absolute;
  bottom: 2px;
}
/* Game */
#game {
  display: none;
  flex-direction: column;
  gap: 8px;
  padding: 8px 0;
}
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.game-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent);
}
.btn {
  border: none;
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: background 0.15s;
}
.btn-primary { background: var(--accent); color: var(--bg); }
.btn-primary:hover { background: var(--accent2); }
.btn-secondary { background: var(--panel2); color: var(--text); }
.btn-secondary:hover { background: var(--border); }
.btn-back { background: transparent; color: var(--text2); font-size: 18px; padding: 4px 8px; }
.tool-row {
  display: flex;
  justify-content: center;
  gap: 6px;
  flex-wrap: wrap;
}
.tool-btn {
  min-width: 40px;
  height: 40px;
  border: 2px solid var(--border);
  border-radius: 8px;
  background: var(--panel);
  color: var(--text);
  font-size: 18px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tool-btn.active { border-color: var(--accent); background: var(--accent); color: var(--bg); }
.tool-btn.erase { font-size: 14px; }
#canvas-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--bg2);
  border-radius: 12px;
  padding: 8px;
}
canvas {
  display: block;
  touch-action: none;
}
.info-bar {
  display: flex;
  justify-content: center;
  gap: 12px;
  font-size: 13px;
  color: var(--text2);
}
.info-bar span { display: flex; align-items: center; gap: 3px; }
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--panel);
  border: 2px solid var(--accent);
  border-radius: 12px;
  padding: 16px 24px;
  font-size: 18px;
  font-weight: 700;
  z-index: 1000;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  text-align: center;
}
.toast.show { opacity: 1; }
.toast.win { border-color: var(--gold); color: var(--gold); font-size: 22px; }
.toast.error { border-color: var(--red); color: var(--red); }
/* Win overlay */
#win-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10, 14, 39, 0.9);
  z-index: 100;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  gap: 16px;
}
#win-overlay.show { display: flex; }
.win-stars { font-size: 40px; }
.win-msg { font-size: 24px; font-weight: 800; color: var(--gold); }
.win-sub { font-size: 14px; color: var(--text2); }
.win-btns { display: flex; gap: 12px; }
/* Settings */
#settings {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10, 14, 39, 0.9);
  z-index: 100;
  justify-content: center;
  align-items: center;
}
#settings.show { display: flex; }
.settings-panel {
  background: var(--panel);
  border-radius: 16px;
  padding: 24px;
  width: 90%;
  max-width: 360px;
}
.settings-panel h2 { color: var(--accent); margin-bottom: 16px; }
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.setting-row:last-of-type { border-bottom: none; }
.toggle {
  width: 44px;
  height: 24px;
  background: var(--border);
  border-radius: 12px;
  position: relative;
  cursor: pointer;
  transition: background 0.2s;
}
.toggle.on { background: var(--accent); }
.toggle::after {
  content: '';
  position: absolute;
  width: 18px;
  height: 18px;
  background: white;
  border-radius: 50%;
  top: 3px;
  left: 3px;
  transition: left 0.2s;
}
.toggle.on::after { left: 23px; }
.confetti {
  position: fixed;
  width: 8px;
  height: 8px;
  pointer-events: none;
  z-index: 99;
}
.game-footer {
  text-align: center;
  padding: 16px 0;
  font-size: 12px;
  color: var(--text2);
}
.game-footer a { color: var(--accent); text-decoration: none; }
</style>
